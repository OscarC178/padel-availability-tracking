# Padel Availability Tracking — credentials
# Copy this file to ".env" (no .example) and fill in the real values.
# .env is gitignored and should never leave this folder.

# Telegram bot token. Generate or rotate via @BotFather on Telegram.
# After rotation, paste the fresh token here.
TELEGRAM_BOT_TOKEN=

# Destination chat id. For a 1:1 chat with the bot, this is your numeric
# Telegram user id (a positive integer, typically 9-10 digits). For a group
# chat, it's a negative integer starting with -100.
# Find it by sending /start to the bot, then visiting:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# The "id" field inside the "chat" object is what you want.
TELEGRAM_CHAT_ID=
